rules_version = '2';

// ============================================================
// CLMS Cloud Storage 보안 규칙
// Phase 1: 인증된 사용자만 읽기/쓰기 허용 (기본 규칙)
// Phase 3 이후 경로별(사업별) 권한 검증으로 강화 예정
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
