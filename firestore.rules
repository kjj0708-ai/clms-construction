rules_version = '2';

// ============================================================
// CLMS Firestore 보안 규칙 (심플 버전)
// users / approval_requests / projects(+소통 하위컬렉션) / counters / 알림
// 명시되지 않은 경로는 기본 거부.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function profileExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() { return profileExists() && myProfile().role == 'system_admin'; }
    function isActive() { return profileExists() && myProfile().status == 'active'; }
    function isOfficer() {
      return isActive() && myProfile().role in
        ['system_admin', 'national_director', 'department_head', 'manager', 'officer'];
    }
    // 부트스트랩 관리자 — 최초 설정 전 누군가 승인해줄 관리자가 없으므로 예외 허용
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'kjj0708@gmail.com';
    }

    // ---- 사용자 ----
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if (isSignedIn() && request.auth.uid == uid
        && request.resource.data.status == 'pending' && request.resource.data.role == 'pending')
        || (isBootstrapAdmin() && request.auth.uid == uid);
      allow update: if isAdmin()
        || (isBootstrapAdmin() && request.auth.uid == uid)
        || (isSignedIn() && request.auth.uid == uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin();

      // 사용자 알림
      match /notifications/{nid} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
        allow create: if isActive();   // 다른 사용자에게 알림 생성 허용
      }
    }

    // ---- 가입 승인 요청 ----
    match /approval_requests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // ---- 사업(개요·진행상황) ----
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create, update: if isOfficer();
      allow delete: if isAdmin();

      // 소통 게시글 (notice|inquiry|instruction)
      match /{collection}/{postId} {
        allow read: if isActive();
        allow create, update: if isActive();
        allow delete: if isAdmin();

        match /comments/{commentId} {
          allow read: if isActive();
          allow create: if isActive();
          allow update: if isActive() && (isAdmin() || resource.data.author.uid == request.auth.uid);
          allow delete: if isAdmin();
        }
      }
    }

    // ---- 사업 ID 채번 카운터 ----
    match /counters/{counterId} {
      allow read: if isActive();
      allow write: if isOfficer();
    }
  }
}
